
TELEGRAM_BOT_TOKEN=

WEBAPP_URL=https://your-project.vercel.app

TELEGRAM_MINIAPP_URL=

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

TON_DEPOSIT_ADDRESS=

# TON Center (toncenter.com) — обязателен для вывода (TonClient); для входящих депозитов сканер сначала ходит сюда, если ключ задан.
TONCENTER_API_KEY=

# TonAPI (tonconsole) — запасной источник списка tx, если Ton Center вернул 0 или ошибку; для Ton Connect bridge он всё равно используется в браузере.
# Только токен, без префикса Bearer и без кавычек.
TONAPI_KEY=

TON_HOT_WALLET_MNEMONIC=
TON_WALLET_VERSION=v4

CRON_SECRET=

# После оплаты через TON Connect: число быстрых повторов скана индекса и пауза (мс), пока tx не появится в выдаче
# DEPOSIT_SUBMIT_SCAN_PASSES=8
# DEPOSIT_SUBMIT_SCAN_DELAY_MS=900

