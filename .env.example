# =============================================================================
# F1 Duel — пример переменных окружения (скопируй в Vercel → Settings → Environment)
# Подробно: docs/WALLET_AND_TESTING.md
# =============================================================================

# --- Telegram (обязательно для API user / WebApp) ---
TELEGRAM_BOT_TOKEN=

# Публичный HTTPS URL вашего фронта (для TonConnect manifest fallback и бота)
WEBAPP_URL=https://your-project.vercel.app

# Ссылка на Mini App для возврата из Tonkeeper: https://t.me/YourBot/yourApp
TELEGRAM_MINIAPP_URL=

# Опционально: вебхук бота
# TELEGRAM_WEBHOOK_SECRET=

# --- Supabase (обязательно; на клиент НЕ выдавать service_role) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# --- TON: адрес приёма депозитов (mainnet). Совпадает с тем, что смотрит cron. ---
TON_DEPOSIT_ADDRESS=

# Mainnet: переменную TON_TESTNET не задавать или оставить пустой.
# Тестнет: TON_TESTNET=1
# TON_TESTNET=

# --- TonAPI (рекомендуется для cron: лимиты и стабильность) ---
TONAPI_KEY=

# --- Cron /api/wallet-cron: защита от чужих вызовов (обязательно в проде) ---
# В Vercel для Cron Jobs обычно задают тот же секрет в заголовке Authorization: Bearer ...
CRON_SECRET=

# --- Горячий кошелёк для автоматического вывода (cron). Храните только на сервере. ---
TON_HOT_WALLET_MNEMONIC=
# v4 | v5r1
TON_WALLET_VERSION=v4

# Опционально свой JSON-RPC вместо дефолтного mainnet
# TON_JSON_RPC_URL=
# TONCENTER_API_KEY=

# --- Лимиты вывода (api/user.js) ---
MIN_WITHDRAWAL_TON=0.05
WITHDRAWAL_RATE_LIMIT_MAX=8
WITHDRAWAL_RATE_LIMIT_WINDOW_SEC=900

# --- Порог и объём сканирования депозитов (wallet-cron) ---
MIN_AUTO_DEPOSIT_TON=0.001
WALLET_CRON_DEPOSIT_TX_LIMIT=30

# Сколько заявок на вывод обрабатывать за один запуск cron
WALLET_CRON_MAX_WITHDRAWALS=1

# Отладка: отключить ветку депозитов/выводов
# WALLET_CRON_DISABLE_DEPOSITS=1
# WALLET_CRON_DISABLE_WITHDRAW=1

# --- Внутренние HTTP-action в api/user.js (если вызываете с другого сервиса) ---
# INTERNAL_API_KEY=
# WALLET_INTERNAL_API_KEY=

# --- Прочее (игры / онлайн — по необходимости) ---
# RECORD_MATCH_BOT_MAX_SCORE=500
# RECORD_MATCH_BOT_MAX_PER_HOUR=80
# PRESENCE_STALE_PRUNE_SEC=300
