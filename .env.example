SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_WEBHOOK_SECRET

WEBAPP_URL=___________________________________
INTERNAL_API_KEY=_____________________________________________
CENTRAL_API_URL=_____________________________________________

# Опционально: отдельный ключ только для walletCreditDepositInternal / complete / fail withdrawal.
# Если задан — игровые серверы с INTERNAL_API_KEY не смогут дергать кошелёк; воркер депозита шлёт этот ключ.
# WALLET_INTERNAL_API_KEY=

# Лимит заявок на вывод с одного Telegram-аккаунта (скользящее окно, по умолчанию 8 за 900 сек).
# WITHDRAWAL_RATE_LIMIT_MAX=8
# WITHDRAWAL_RATE_LIMIT_WINDOW_SEC=900

# TON: адрес для пополнений (один на проект). Пользователям показывается + личный тег в комментарии.
# Для автовывода адрес должен совпадать с кошельком из TON_HOT_WALLET_MNEMONIC (v4 по умолчанию).
TON_DEPOSIT_ADDRESS=

# --- Автокошелёк (Vercel Cron → GET /api/wallet-cron каждую минуту) ---
# Обязательно: случайная длинная строка. Vercel подставит Bearer при вызове крона, если CRON_SECRET задан в проекте.
CRON_SECRET=

# Мнемоника горячего кошелька (24 слова через пробел). Тот же кошёлёк = TON_DEPOSIT_ADDRESS. Не коммить.
# TON_HOT_WALLET_MNEMONIC=

# RPC Toncenter (рекомендуется API key с https://toncenter.com)
# TON_JSON_RPC_URL=https://toncenter.com/api/v2/jsonRPC
# TONCENTER_API_KEY=

# TonAPI для чтения транзакций (опционально ключ — выше лимитов)
# TONAPI_KEY=

# Тестнет: TON_TESTNET=1 и testnet RPC / tonapi.testnet
# TON_TESTNET=0

# Версия кошелька из мнемоники: v4 | v5 (если адрес не совпадает — попробуй v5)
# TON_WALLET_VERSION=v4

# Мин. сумма для автозачисления депозита (TON)
# MIN_AUTO_DEPOSIT_TON=0.001

# Сколько pending-выводов обрабатывать за один запуск крона (по умолчанию 1)
# WALLET_CRON_MAX_WITHDRAWALS=1

# Если отправили TON, но хэш не нашли: через столько мс откат заявки (возврат баланса). По умолчанию 1 час.
# AUTO_WITHDRAW_STALE_MS=3600000

# Пауза перед поиском исходящей tx после send (мс)
# AUTO_WITHDRAW_POLL_MS=4000

# Минимальная сумма вывода в TON (если не задано — 0.05)
# MIN_WITHDRAWAL_TON=0.05

# Optional: remove stale presence rows if the client never sent presenceLeave (killed app). Seconds 120–7200, default 300.
# PRESENCE_STALE_PRUNE_SEC=300

# Optional: limits for public action recordMatch (bot-only). Max score per player default 500; max rows per user per hour default 80.
# RECORD_MATCH_BOT_MAX_SCORE=500
# RECORD_MATCH_BOT_MAX_PER_HOUR=80
