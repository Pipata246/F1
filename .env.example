
TELEGRAM_BOT_TOKEN=

WEBAPP_URL=https://your-project.vercel.app

TELEGRAM_MINIAPP_URL=

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

TON_DEPOSIT_ADDRESS=

# TonAPI (tonapi.io) — уже используется в коде для списка транзакций (депозиты, проверка вывода). Ключ: https://tonconsole.com → проект → API
# Только токен, без префикса Bearer и без кавычек.
TONAPI_KEY=

# TON Center (toncenter.com) — JSON-RPC для @ton/ton: seqno кошелька и отправка вывода. Ключ в кабинете https://toncenter.com
TONCENTER_API_KEY=

TON_HOT_WALLET_MNEMONIC=
TON_WALLET_VERSION=v4

CRON_SECRET=

# --- Заявки на пополнение (deposit_intents) ---
# Сколько минут ждать оплату после создания заявки (pending)
# DEPOSIT_INTENT_TTL_MIN=45
# После успешной отправки tx в кошельке — продление expires_at (минут), по умолчанию 48ч
# DEPOSIT_INTENT_SUBMIT_TTL_MIN=2880
# Максимум незакрытых заявок на пользователя
# DEPOSIT_INTENT_MAX_OPEN=8

# Мин. интервал между syncMyDeposits (сек), защита от спама TonAPI
# DEPOSIT_SYNC_MIN_INTERVAL_SEC=10

